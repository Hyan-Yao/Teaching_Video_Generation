# Copy this file to `.env` and fill in your real secrets.
# `.env` is git-ignored; this template is safe to commit.
#
# Each variable follows the pattern {SERVICE}_{KEY} (uppercase) and overrides
# the corresponding entry in api_config.json at runtime (see cfg() in gpt_request.py).

# OpenAI (gpt5)
GPT5_API_KEY=

# Other services (uncomment and fill in as needed)
# GEMINI_API_KEY=
# GPT41_API_KEY=
# GPT4O_API_KEY=
# CLAUDE_API_KEY=
# ICONFINDER_API_KEY=
